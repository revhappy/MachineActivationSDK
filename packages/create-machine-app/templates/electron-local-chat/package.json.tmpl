{
  "name": "{{APP_NAME}}",
  "version": "0.1.0",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json --watch\" \"wait-on tcp:5173 dist/electron/main.js && electron dist/electron/main.js\"",
    "fetch:llama": "node ./scripts/fetch-llama-cpp.js",
    "typecheck:main": "tsc --noEmit -p tsconfig.main.json",
    "bundle:main": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --target=node20 --format=cjs --external:electron --outdir=dist/electron",
    "build:renderer": "vite build",
    "build": "npm run fetch:llama && npm run typecheck:main && npm run bundle:main && npm run build:renderer",
    "start": "electron dist/electron/main.js",
    "prepackage": "node ./scripts/prepackage.js",
    "package": "electron-builder",
    "tsc": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "machineai-activation": "^0.1.0-alpha.1",
    "machineai-activation-ui": "^0.1.0-alpha.1",
    "@mediapipe/tasks-genai": "^0.10.27",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.example.{{APP_NAME}}",
    "productName": "{{APP_NAME}}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json",
      "!node_modules/machineai-activation-**/*"
    ],
    "extraResources": [
      {
        "from": "vendor/llama-cpp",
        "to": "llama-cpp",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
